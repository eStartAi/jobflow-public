# =========================
# PROVIDER
# =========================
MODEL_PROVIDER=openrouter

# =========================
# OPENROUTER CONFIG
# =========================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =========================
# MODEL TIERS
# =========================
FAST_MODEL=mistralai/mistral-7b-instruct
BALANCED_MODEL=meta-llama/llama-3-8b-instruct
SMART_MODEL=openai/gpt-4o-mini

FALLBACK_MODEL_1=anthropic/claude-3-haiku
FALLBACK_MODEL_2=mistralai/mixtral-8x7b-instruct

# =========================
# CACHE + LOGGING
# =========================
ENABLE_CACHE=true
CACHE_FILE=cache.json
LOG_FILE=logs/ai.log

# =========================
# CONTROL
# =========================
MODEL_TIMEOUT=12
MAX_RETRIES=1

# =========================
# SERVER
# =========================
PORT=8090
